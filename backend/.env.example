# FinSight environment variables — copy to .env and fill in as needed.
# The project runs fully free with no required API keys.

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# CORS — comma-separated allowed origins (defaults to * in dev)
# CORS_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Override model paths if you have local copies
# FINBERT_MODEL_PATH=./models/finbert
# EMBED_MODEL_PATH=./models/all-MiniLM-L6-v2
# CHAT_MODEL_PATH=./models/flan-t5-base

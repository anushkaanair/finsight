# FinSight Environment Variables
# Copy this to .env and fill in your values

# Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Flask
FLASK_ENV=development
FLASK_PORT=5000

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. Without this, tokens reset on every server restart.
JWT_SECRET_KEY=change_me_generate_a_real_secret
